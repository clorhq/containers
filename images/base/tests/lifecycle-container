#!/bin/bash
# Run after building the production image. This verifies signals sent to the
# container PID traverse dumb-init and the coordinator's real process groups.
set -o errexit
set -o nounset
set -o pipefail

if (($# != 1)); then
    printf 'usage: %s IMAGE\n' "$0" >&2
    exit 2
fi

IMAGE="$1"
SCRIPT_DIRECTORY="$(cd "$(dirname "$0")" && pwd)"
STATE_DIRECTORY="$(mktemp --directory)"
CONTAINER_NAME="clor-lifecycle-test-$$"
TOP_FILE="${STATE_DIRECTORY}/container-top"
# shellcheck disable=SC2016 # Expanded by the archive login shell.
ARCHIVE_SCRIPT='set -o errexit
set -o nounset
printf "start\n" >>/state/archive-starts
printf "%s" "$$" >/state/archive.pid
bash /runtime-archive-child &
CHILD="$!"
wait "${CHILD}"
'
ARCHIVE_SCRIPT_BASE64="$(printf '%s' "${ARCHIVE_SCRIPT}" | base64 --wrap=0)"

cleanup() {
    docker rm --force "${CONTAINER_NAME}" >/dev/null 2>&1 || true
    rm --recursive --force "${STATE_DIRECTORY}"
}
trap cleanup EXIT

chmod 0777 "${STATE_DIRECTORY}"
docker run --detach \
    --name "${CONTAINER_NAME}" \
    --volume "${STATE_DIRECTORY}:/state" \
    --volume "${SCRIPT_DIRECTORY}/lifecycle-runtime-entrypoint:/runtime-entrypoint:ro" \
    --volume "${SCRIPT_DIRECTORY}/lifecycle-runtime-archive-child:/runtime-archive-child:ro" \
    --volume "${SCRIPT_DIRECTORY}/lifecycle-runtime-tab:/runtime-tab:ro" \
    --env "CLOR_ARCHIVE_SCRIPT_BASE64=${ARCHIVE_SCRIPT_BASE64}" \
    --entrypoint /usr/bin/dumb-init \
    "${IMAGE}" \
    --single-child -- \
    /usr/local/lib/clor/lifecycle bash /runtime-entrypoint >/dev/null

wait_for_file() {
    local path="$1"
    local attempt

    for ((attempt = 0; attempt < 100; attempt++)); do
        if [[ -f "${path}" ]]; then
            return 0
        fi
        sleep 0.05
    done
    printf 'lifecycle container test: timed out waiting for %s\n' "${path}" >&2
    return 1
}

wait_for_container_file() {
    local path="$1"
    local attempt

    for ((attempt = 0; attempt < 300; attempt++)); do
        if docker exec "${CONTAINER_NAME}" test -e "${path}"; then
            return 0
        fi
        sleep 0.1
    done
    printf 'lifecycle container test: timed out waiting for container file %s\n' \
        "${path}" >&2
    return 1
}

wait_for_file "${STATE_DIRECTORY}/workload-child.pid"
docker kill --signal USR1 "${CONTAINER_NAME}" >/dev/null
docker kill --signal USR1 "${CONTAINER_NAME}" >/dev/null
wait_for_file "${STATE_DIRECTORY}/archive-child.pid"

if docker exec "${CONTAINER_NAME}" \
    kill -0 "$(<"${STATE_DIRECTORY}/workload-child.pid")" 2>/dev/null; then
    printf 'lifecycle container test: tab service was still running during archive\n' >&2
    exit 1
fi
docker exec "${CONTAINER_NAME}" \
    kill -0 "$(<"${STATE_DIRECTORY}/archive-child.pid")"
docker top "${CONTAINER_NAME}" -eo pid |
    awk 'NR > 1 { print $1 }' >"${TOP_FILE}"

docker wait "${CONTAINER_NAME}" >/dev/null
EXIT_CODE="$(docker inspect --format '{{.State.ExitCode}}' "${CONTAINER_NAME}")"
if [[ "${EXIT_CODE}" != 0 ]]; then
    printf 'lifecycle container test: exit code %s, want 0\n' "${EXIT_CODE}" >&2
    exit 1
fi
if [[ "$(grep --count '^start$' "${STATE_DIRECTORY}/archive-starts")" != 1 ]]; then
    printf 'lifecycle container test: archive did not run exactly once\n' >&2
    exit 1
fi
if [[ -e "${STATE_DIRECTORY}/archive-child-signals" ]]; then
    printf 'lifecycle container test: repeated SIGUSR1 reached archive descendants\n' >&2
    exit 1
fi
grep --fixed-strings --quiet term "${STATE_DIRECTORY}/workload-child-signals"

while IFS= read -r host_pid; do
    [[ -n "${host_pid}" ]] || continue
    for attempt in {1..40}; do
        if ! ps -p "${host_pid}" >/dev/null 2>&1; then
            break
        fi
        sleep 0.05
    done
    if ps -p "${host_pid}" >/dev/null 2>&1; then
        printf 'lifecycle container test: host process %s lingered after exit\n' \
            "${host_pid}" >&2
        exit 1
    fi
done <"${TOP_FILE}"

docker rm --force "${CONTAINER_NAME}" >/dev/null
rm --recursive --force "${STATE_DIRECTORY:?}"/*
CONTAINER_NAME="clor-lifecycle-term-test-$$"
docker run --detach \
    --name "${CONTAINER_NAME}" \
    --volume "${STATE_DIRECTORY}:/state" \
    --volume "${SCRIPT_DIRECTORY}/lifecycle-runtime-entrypoint:/runtime-entrypoint:ro" \
    --volume "${SCRIPT_DIRECTORY}/lifecycle-runtime-tab:/runtime-tab:ro" \
    --entrypoint /usr/bin/dumb-init \
    "${IMAGE}" \
    --single-child -- \
    /usr/local/lib/clor/lifecycle bash /runtime-entrypoint >/dev/null

wait_for_file "${STATE_DIRECTORY}/workload-child.pid"
STARTED_AT="${SECONDS}"
docker kill --signal TERM "${CONTAINER_NAME}" >/dev/null
docker wait "${CONTAINER_NAME}" >/dev/null
if ((SECONDS - STARTED_AT >= 30)); then
    printf 'lifecycle container test: ordinary shutdown exceeded 30 seconds\n' >&2
    exit 1
fi
EXIT_CODE="$(docker inspect --format '{{.State.ExitCode}}' "${CONTAINER_NAME}")"
if [[ "${EXIT_CODE}" != 143 ]]; then
    printf 'lifecycle container test: SIGTERM exit code %s, want 143\n' \
        "${EXIT_CODE}" >&2
    exit 1
fi
grep --fixed-strings --quiet term "${STATE_DIRECTORY}/workload-child-signals"
if [[ -e "${STATE_DIRECTORY}/archive-starts" ]]; then
    printf 'lifecycle container test: SIGTERM unexpectedly ran the archive\n' >&2
    exit 1
fi

for invalid_variable in CLOR_SETUP_SCRIPT_BASE64 CLOR_ARCHIVE_SCRIPT_BASE64; do
    docker rm --force "${CONTAINER_NAME}" >/dev/null
    rm --recursive --force "${STATE_DIRECTORY:?}"/*
    CONTAINER_NAME="clor-lifecycle-invalid-test-$$-${invalid_variable,,}"
    docker run --detach \
        --name "${CONTAINER_NAME}" \
        --volume "${STATE_DIRECTORY}:/state" \
        --volume "${SCRIPT_DIRECTORY}/lifecycle-runtime-entrypoint:/runtime-entrypoint:ro" \
        --env "${invalid_variable}=not-valid-base64" \
        --entrypoint /usr/bin/dumb-init \
        "${IMAGE}" \
        --single-child -- \
        /usr/local/lib/clor/lifecycle bash /runtime-entrypoint >/dev/null
    docker wait "${CONTAINER_NAME}" >/dev/null
    EXIT_CODE="$(docker inspect --format '{{.State.ExitCode}}' "${CONTAINER_NAME}")"
    if [[ "${EXIT_CODE}" != 1 ]]; then
        printf 'lifecycle container test: invalid %s exit code %s, want 1\n' \
            "${invalid_variable}" "${EXIT_CODE}" >&2
        exit 1
    fi
    if [[ -e "${STATE_DIRECTORY}/workload.pid" ]]; then
        printf 'lifecycle container test: invalid %s started the workload\n' \
            "${invalid_variable}" >&2
        exit 1
    fi
done

docker rm --force "${CONTAINER_NAME}" >/dev/null
CONTAINER_NAME="clor-lifecycle-readiness-test-$$"
docker run --detach \
    --name "${CONTAINER_NAME}" \
    --volume "${SCRIPT_DIRECTORY}/bin/clor:/home/user/.local/bin/clor:ro" \
    --volume "${SCRIPT_DIRECTORY}/bin/curl:/usr/local/bin/curl:ro" \
    "${IMAGE}" >/dev/null
wait_for_container_file /run/clor/ready
docker exec "${CONTAINER_NAME}" nc -z 127.0.0.1 6000
STARTED_AT="${SECONDS}"
docker kill --signal TERM "${CONTAINER_NAME}" >/dev/null
docker wait "${CONTAINER_NAME}" >/dev/null
if ((SECONDS - STARTED_AT >= 30)); then
    printf 'lifecycle container test: managed shutdown exceeded 30 seconds\n' >&2
    exit 1
fi
EXIT_CODE="$(docker inspect --format '{{.State.ExitCode}}' "${CONTAINER_NAME}")"
if [[ "${EXIT_CODE}" != 143 ]]; then
    printf 'lifecycle container test: managed SIGTERM exit code %s, want 143\n' \
        "${EXIT_CODE}" >&2
    exit 1
fi
