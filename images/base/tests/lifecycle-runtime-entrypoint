#!/bin/bash
set -o errexit
set -o nounset
set -o pipefail

STATE_DIRECTORY="/state"
LIFECYCLE_DIRECTORY="/run/clor/lifecycle"
SERVICES_DIRECTORY="/etc/service"

mkdir --parents "${LIFECYCLE_DIRECTORY}"
printf '%s' /home/user >"${LIFECYCLE_DIRECTORY}/archive-directory"
: >"${LIFECYCLE_DIRECTORY}/workload-started"
: >/run/clor/ready
printf '%s' "$$" >"${STATE_DIRECTORY}/workload.pid"
mkdir --parents "${SERVICES_DIRECTORY}/tab-runtime"
cp /runtime-tab "${SERVICES_DIRECTORY}/tab-runtime/run"
chmod 0755 "${SERVICES_DIRECTORY}/tab-runtime/run"
exec runsvdir -P "${SERVICES_DIRECTORY}"
