#!/bin/bash
# Prepare the space, repository, setup script, and supervised services.
# This entrypoint runs only inside a fresh sandbox container. Host-backed
# spaces never execute it or the Git setup commands below.
set -o errexit
set -o nounset
set -o pipefail
set -o xtrace

SPACE_USER="${CLOR_SPACE_USER:-user}"
SPACE_HOME="${CLOR_SPACE_HOME:-/home/user}"
SPACE_DIRECTORY="${CLOR_SPACE_DIRECTORY:-${SPACE_HOME}}"
SPACE_PATH_PREFIX="${CLOR_SPACE_PATH_PREFIX:-}"
SPACE_PATH="${SPACE_HOME}/.local/bin:${SPACE_HOME}/go/bin:${SPACE_HOME}/.npm-global/bin"
if [[ -n "${SPACE_PATH_PREFIX}" ]]; then
    SPACE_PATH="${SPACE_PATH}:${SPACE_PATH_PREFIX}"
fi
SPACE_PATH="${SPACE_PATH}:${PATH}"
SPACE_PLAYWRIGHT_BROWSERS_PATH="${SPACE_HOME}/.cache/ms-playwright"
REPOSITORY_URL="${CLOR_REPOSITORY_URL:-}"
REPOSITORY_BRANCH="${CLOR_REPOSITORY_BRANCH:-}"
REPOSITORY_SHALLOW="${CLOR_REPOSITORY_SHALLOW:-false}"
REPOSITORY_DIRECTORY="${CLOR_REPOSITORY_DIRECTORY:-}"
AGENT_CONFIG_ID="${CLOR_AGENT_CONFIG_ID:-}"
SETUP_FINGERPRINT_FILE="/var/lib/clor/setup-fingerprint"
SERVICES_DIRECTORY="/etc/service"
LOGS_DIRECTORY="/var/log"
READY_FILE="/run/clor/ready"
LIFECYCLE_DIRECTORY="/run/clor/lifecycle"
ARCHIVE_DIRECTORY_FILE="${LIFECYCLE_DIRECTORY}/archive-directory"
WORKLOAD_STARTED_FILE="${LIFECYCLE_DIRECTORY}/workload-started"
SETUP_SCRIPT_FILE="${LIFECYCLE_DIRECTORY}/setup-script"
# Must match spacespec.CredentialsReadyFile: the space daemon writes this
# marker after its first credential pass in every outcome, and tab services
# wait on it (bounded) before starting their agents.
CREDENTIALS_READY_FILE="/run/clor/space-daemon/credentials-ready"
CREDENTIALS_READY_TIMEOUT_SECONDS="20"
READINESS_TIMEOUT_SECONDS="300"
MAX_NETWORK_ATTEMPTS="5"
declare -a READINESS_PORTS=(6000)

bootstrap_error() {
    printf 'bootstrap: %s\n' "$*" >&2
}

as_space_user() {
    gosu "${SPACE_USER}" env \
        HOME="${SPACE_HOME}" \
        USER="${SPACE_USER}" \
        LOGNAME="${SPACE_USER}" \
        PATH="${SPACE_PATH}" \
        PLAYWRIGHT_BROWSERS_PATH="${SPACE_PLAYWRIGHT_BROWSERS_PATH}" \
        "$@"
}

git_in_directory() {
    local directory="$1"
    shift

    # Git has no long spelling for -C.
    as_space_user git -C "${directory}" "$@"
}

shell_quote() {
    local destination="$1"
    local value="$2"

    # Bash printf has no long spelling for -v; %q makes generated shell safe.
    printf -v "${destination}" '%q' "${value}"
}

list_variables() {
    local pattern="$1"

    # Bash compgen has no long spelling for -A.
    compgen -A variable | grep --extended-regexp "${pattern}" || true
}

retry_network() {
    local description="$1"
    local attempt
    shift

    for ((attempt = 1; attempt <= MAX_NETWORK_ATTEMPTS; attempt++)); do
        if "$@"; then
            return 0
        fi
        if ((attempt < MAX_NETWORK_ATTEMPTS)); then
            sleep "$((attempt * 5))"
        fi
    done
    bootstrap_error "${description} failed after ${MAX_NETWORK_ATTEMPTS} attempts; check the configuration and network access"
    return 1
}

clear_readiness() {
    # Readiness describes this boot only, including failures before setup.
    rm --force "${READY_FILE}"
    # A stale marker from a previous boot must not pre-satisfy the tab wait.
    rm --force "${CREDENTIALS_READY_FILE}"
}

validate_configuration() {
    if [[ -n "${REPOSITORY_URL}" && -z "${REPOSITORY_DIRECTORY}" ]]; then
        REPOSITORY_DIRECTORY="$(basename "${REPOSITORY_URL%.git}")"
    fi

    if [[ -n "${REPOSITORY_DIRECTORY}" ]] &&
        [[ "${REPOSITORY_DIRECTORY}" == "." ||
            "${REPOSITORY_DIRECTORY}" == ".." ||
            "${REPOSITORY_DIRECTORY}" == /* ||
            "${REPOSITORY_DIRECTORY}" == ../* ||
            "${REPOSITORY_DIRECTORY}" == */../* ||
            "${REPOSITORY_DIRECTORY}" == */.. ]]; then
        bootstrap_error "repository directory must be a safe relative path, got '${REPOSITORY_DIRECTORY}'"
        return 1
    fi
}

prepare_user_state() {
    local directory
    local -a directories=(
        "${SPACE_HOME}"
        "${SPACE_HOME}/.cache"
        "${SPACE_HOME}/.claude"
        "${SPACE_HOME}/.clor"
        "${SPACE_HOME}/.codex"
        "${SPACE_HOME}/.config"
        "${SPACE_HOME}/.local"
        "${SPACE_DIRECTORY}"
        # The space daemon runs as the space user and writes the
        # credentials-ready marker here; /run/clor itself stays root-owned.
        "$(dirname "${CREDENTIALS_READY_FILE}")"
    )

    mkdir --parents "${directories[@]}"
    for directory in "${directories[@]}"; do
        chown "${SPACE_USER}:${SPACE_USER}" "${directory}"
        chmod u+rwx "${directory}"
    done
}

update_clor() {
    # A transient update failure must not hide the baked Clor release.
    if ! curl --fail --silent --show-error --location https://clor.com/install.sh |
        as_space_user bash >/dev/null; then
        bootstrap_error "Clor update failed; continuing with the baked release"
    fi
}

clor_login() {
    local login_status

    # Keep entrypoint tracing enabled without printing the login key.
    set +o xtrace
    printf '%s\n' "${CLOR_API_KEY}" |
        as_space_user clor account login --key-standard-input >/dev/null
    login_status="$?"
    set -o xtrace
    return "${login_status}"
}

clor_api_key_is_set() {
    local key_is_set="false"

    # Xtrace renders conditional operands, so inspect the key while muted.
    set +o xtrace
    if [[ -n "${CLOR_API_KEY:-}" ]]; then
        key_is_set="true"
    fi
    set -o xtrace
    [[ "${key_is_set}" == "true" ]]
}

install_agent_config() {
    as_space_user clor agent config install "$1" >/dev/null
}

configure_clor() {
    update_clor

    if ! clor_api_key_is_set; then
        return 0
    fi

    retry_network "Clor login" clor_login
    # Inside a space, `clor install skill` installs exactly the skills
    # attached to this space, authenticated by the space identity key, so
    # it runs after login rather than before like the old plugin install.
    if ! as_space_user clor install skill >/dev/null; then
        bootstrap_error "Clor skill installation failed; continuing without skills"
    fi
    if ! as_space_user clor repo git setup >/dev/null; then
        bootstrap_error "Clor repository Git setup failed; verify the account configuration"
        return 1
    fi
    if [[ -n "${CLOR_GITHUB_CONNECTION_ID:-}" ]] &&
        ! as_space_user clor github git setup >/dev/null; then
        bootstrap_error "Clor GitHub Git setup failed; verify CLOR_GITHUB_CONNECTION_ID"
        return 1
    fi
    if [[ -n "${AGENT_CONFIG_ID}" ]]; then
        retry_network "agent config '${AGENT_CONFIG_ID}' installation" \
            install_agent_config "${AGENT_CONFIG_ID}"
    fi
}

clone_repository() {
    local url="$1"
    local reference="$2"
    local shallow="$3"
    local staging_directory="$4"
    local -a clone_arguments=(clone)

    # Staging is a disposable sibling so the destination changes atomically.
    rm --recursive --force "${staging_directory}" || return
    mkdir "${staging_directory}" || return
    chown "${SPACE_USER}:${SPACE_USER}" "${staging_directory}" || return

    if [[ -z "${reference}" ]]; then
        if [[ "${shallow}" == "true" ]]; then
            clone_arguments+=(--depth 1)
        fi
        as_space_user git "${clone_arguments[@]}" "${url}" "${staging_directory}"
        return
    fi

    # Tags and commits require the full-clone fallback.
    if [[ "${shallow}" == "true" ]] &&
        as_space_user git ls-remote --exit-code --heads \
            "${url}" "${reference}" >/dev/null 2>&1; then
        as_space_user git clone --depth 1 --branch "${reference}" \
            "${url}" "${staging_directory}"
        return
    fi

    as_space_user git clone "${url}" "${staging_directory}" &&
        git_in_directory "${staging_directory}" checkout --quiet "${reference}"
}

ensure_checkout() {
    local url="$1"
    local reference="$2"
    local shallow="$3"
    local destination="$4"
    local staging_directory="${destination}.partial"
    local existing_origin
    local parent_directory

    if [[ -L "${destination}" ]]; then
        bootstrap_error "repository destination '${destination}' must not be a symbolic link"
        return 1
    fi
    if [[ -e "${destination}" && ! -d "${destination}" ]]; then
        bootstrap_error "repository destination '${destination}' exists and is not a directory"
        return 1
    fi
    if [[ -d "${destination}/.git" ]]; then
        chown --recursive "${SPACE_USER}:${SPACE_USER}" "${destination}"
        if ! existing_origin="$(git_in_directory "${destination}" remote get-url origin)"; then
            bootstrap_error "repository checkout '${destination}' has no readable origin"
            return 1
        fi
        if [[ "${existing_origin}" != "${url}" ]]; then
            bootstrap_error "repository checkout '${destination}' tracks '${existing_origin}', expected '${url}'"
            return 1
        fi
        return 0
    fi
    # These find predicates have no long forms.
    if [[ -d "${destination}" ]] &&
        [[ -n "$(find "${destination}" -mindepth 1 -maxdepth 1 -print -quit)" ]]; then
        bootstrap_error "repository destination '${destination}' is not empty and is not a Git checkout"
        return 1
    fi

    parent_directory="$(dirname "${destination}")"
    mkdir --parents "${parent_directory}"
    chown "${SPACE_USER}:${SPACE_USER}" "${parent_directory}"
    retry_network "repository clone from '${url}'" \
        clone_repository "${url}" "${reference}" "${shallow}" "${staging_directory}"
    if [[ -d "${destination}" ]]; then
        rmdir "${destination}"
    fi
    mv "${staging_directory}" "${destination}"
}

mark_repository_safe() {
    local directory="$1"

    if as_space_user git config --global --get-all --fixed-value \
        safe.directory "${directory}" >/dev/null; then
        return 0
    fi
    if ! as_space_user git config --global --add safe.directory "${directory}"; then
        bootstrap_error "could not mark repository checkout '${directory}' as safe for '${SPACE_USER}'"
        return 1
    fi
}

prepare_repository() {
    local destination=""

    if [[ -n "${REPOSITORY_URL}" ]]; then
        destination="${SPACE_DIRECTORY}/${REPOSITORY_DIRECTORY}"
        if ! ensure_checkout "${REPOSITORY_URL}" "${REPOSITORY_BRANCH}" \
            "${REPOSITORY_SHALLOW}" "${destination}"; then
            return 1
        fi
        if ! mark_repository_safe "${destination}"; then
            return 1
        fi
    fi
    printf '%s' "${destination}"
}

write_setup_fingerprint() {
    local fingerprint="$1"
    local temporary_file

    mkdir --parents "$(dirname "${SETUP_FINGERPRINT_FILE}")"
    if ! temporary_file="$(mktemp "${SETUP_FINGERPRINT_FILE}.tmp.XXXXXX")"; then
        bootstrap_error "could not create a temporary setup fingerprint"
        return 1
    fi
    if ! printf '%s' "${fingerprint}" >"${temporary_file}"; then
        rm --force "${temporary_file}"
        bootstrap_error "could not write the setup fingerprint"
        return 1
    fi
    if ! mv --force "${temporary_file}" "${SETUP_FINGERPRINT_FILE}"; then
        rm --force "${temporary_file}"
        bootstrap_error "could not replace the setup fingerprint"
        return 1
    fi
}

prepare_setup_script() {
    local decode_succeeded="true"
    local tracing_enabled="false"
    local temporary_file

    prepare_lifecycle_metadata
    temporary_file="$(mktemp "${LIFECYCLE_DIRECTORY}/setup-script.tmp.XXXXXX")"

    if [[ "$-" == *x* ]]; then
        tracing_enabled="true"
        set +o xtrace
    fi
    if ! printf '%s' "${CLOR_SETUP_SCRIPT_BASE64:-}" |
        base64 --decode >"${temporary_file}"; then
        decode_succeeded="false"
    fi
    unset -- CLOR_SETUP_SCRIPT_BASE64 CLOR_ARCHIVE_SCRIPT_BASE64
    if [[ "${tracing_enabled}" == "true" ]]; then
        set -o xtrace
    fi
    if [[ "${decode_succeeded}" != "true" ]]; then
        rm --force "${temporary_file}"
        bootstrap_error "CLOR_SETUP_SCRIPT_BASE64 is not valid Base64"
        return 1
    fi
    chown "${SPACE_USER}:${SPACE_USER}" "${temporary_file}"
    chmod 0400 "${temporary_file}"
    mv --force "${temporary_file}" "${SETUP_SCRIPT_FILE}"
}

cleanup_setup_script() {
    rm --force "${SETUP_SCRIPT_FILE}"
}

run_setup_script() {
    local repository_destination="$1"
    local fingerprint="${CLOR_BOOTSTRAP_FINGERPRINT:-}"
    local working_directory="${SPACE_HOME}"

    if [[ ! -s "${SETUP_SCRIPT_FILE}" ]]; then
        return 0
    fi
    if [[ -f "${SETUP_FINGERPRINT_FILE}" ]] &&
        [[ "$(<"${SETUP_FINGERPRINT_FILE}")" == "${fingerprint}" ]]; then
        return 0
    fi
    if [[ -n "${repository_destination}" ]]; then
        working_directory="${repository_destination}"
    fi

    if ! (cd "${working_directory}" &&
        as_space_user bash --login "${SETUP_SCRIPT_FILE}"); then
        bootstrap_error "setup script failed in '${working_directory}'; readiness withheld so the failure surfaces"
        return 1
    fi
    if ! write_setup_fingerprint "${fingerprint}"; then
        bootstrap_error "setup completed but its fingerprint could not be saved; readiness withheld"
        return 1
    fi
}

clear_managed_services() {
    mkdir --parents "${SERVICES_DIRECTORY}"
    # The trailing slash traverses Debian runit's /etc/service symlink.
    # These find predicates have no long forms.
    find "${SERVICES_DIRECTORY}/" -mindepth 1 -maxdepth 1 \
        \( -name code-server -o -name readiness -o -name space-daemon -o -name 'tab-*' \) \
        -exec rm --recursive --force -- {} +
}

generate_service_logger() {
    local service_name="$1"
    local service_directory="${SERVICES_DIRECTORY}/${service_name}"
    local log_directory="${LOGS_DIRECTORY}/${service_name}"
    local quoted_log_directory

    mkdir --parents "${service_directory}/log" "${log_directory}"
    cat >"${log_directory}/config" <<'CONFIG'
s100000000
n3
CONFIG
    shell_quote quoted_log_directory "${log_directory}"
    # svlogd exposes only short options.
    cat >"${service_directory}/log/run" <<RUN
#!/bin/bash
exec svlogd -tt -l 1023 -b 1048576 ${quoted_log_directory}
RUN
    chmod 0755 "${service_directory}/log/run"
}

generate_space_daemon_service() {
    local service_name="space-daemon"
    local service_directory="${SERVICES_DIRECTORY}/${service_name}"
    local quoted_user
    local quoted_home
    local quoted_user_environment
    local quoted_logname
    local quoted_path
    local quoted_playwright_browsers_path

    mkdir --parents "${service_directory}"
    shell_quote quoted_user "${SPACE_USER}"
    shell_quote quoted_home "HOME=${SPACE_HOME}"
    shell_quote quoted_user_environment "USER=${SPACE_USER}"
    shell_quote quoted_logname "LOGNAME=${SPACE_USER}"
    shell_quote quoted_path "PATH=${SPACE_PATH}"
    shell_quote quoted_playwright_browsers_path \
        "PLAYWRIGHT_BROWSERS_PATH=${SPACE_PLAYWRIGHT_BROWSERS_PATH}"
    cat >"${service_directory}/run" <<RUN
#!/bin/bash
exec 2>&1
exec gosu ${quoted_user} env \\
    ${quoted_home} ${quoted_user_environment} ${quoted_logname} ${quoted_path} \\
    ${quoted_playwright_browsers_path} \\
    clor space daemon
RUN
    chmod 0755 "${service_directory}/run"
    generate_service_logger "${service_name}"
}

generate_code_server_service() {
    local service_name="code-server"
    local service_directory="${SERVICES_DIRECTORY}/${service_name}"
    local quoted_space_directory
    local quoted_user
    local quoted_home
    local quoted_user_environment
    local quoted_logname
    local quoted_path
    local quoted_playwright_browsers_path

    mkdir --parents "${service_directory}"
    shell_quote quoted_space_directory "${SPACE_DIRECTORY}"
    shell_quote quoted_user "${SPACE_USER}"
    shell_quote quoted_home "HOME=${SPACE_HOME}"
    shell_quote quoted_user_environment "USER=${SPACE_USER}"
    shell_quote quoted_logname "LOGNAME=${SPACE_USER}"
    shell_quote quoted_path "PATH=${SPACE_PATH}"
    shell_quote quoted_playwright_browsers_path \
        "PLAYWRIGHT_BROWSERS_PATH=${SPACE_PLAYWRIGHT_BROWSERS_PATH}"
    cat >"${service_directory}/run" <<RUN
#!/bin/bash
exec 2>&1
cd ${quoted_space_directory}
exec gosu ${quoted_user} env \\
    ${quoted_home} ${quoted_user_environment} ${quoted_logname} ${quoted_path} \\
    ${quoted_playwright_browsers_path} \\
    code-server --auth none --disable-telemetry --disable-workspace-trust \\
        --disable-getting-started-override \\
        --bind-addr 0.0.0.0:6000 .
RUN
    chmod 0755 "${service_directory}/run"
    generate_service_logger "${service_name}"
}

generate_tab_service() {
    local tab_token="$1"
    local command_variable="CLOR_TAB_${tab_token}_COMMAND"
    local port_variable="CLOR_TAB_${tab_token}_PORT"
    local secret_variable="CLOR_TAB_${tab_token}_WEBTUI_SECRET"
    local direct_token_variable="CLOR_TAB_${tab_token}_DIRECT_TOKEN"
    local directory_variable="CLOR_TAB_${tab_token}_WORKING_DIRECTORY"
    local tab_command="${!command_variable:-}"
    local tab_port="${!port_variable:-}"
    local tab_secret="${!secret_variable:-}"
    local tab_direct_token="${!direct_token_variable:-}"
    local tab_working_directory="${!directory_variable:-${SPACE_HOME}}"
    local service_name
    local service_directory
    local environment_file
    local quoted_tab_command
    local quoted_tab_port
    local quoted_tab_secret
    local quoted_tab_direct_token
    local quoted_tab_working_directory
    local quoted_environment_file
    local quoted_credentials_ready_file
    local quoted_user
    local quoted_home
    local quoted_user_environment
    local quoted_logname
    local quoted_path
    local quoted_playwright_browsers_path

    if [[ -z "${tab_command}" ]]; then
        bootstrap_error "${command_variable} must contain a command"
        return 1
    fi
    if [[ -z "${tab_port}" ]]; then
        bootstrap_error "${port_variable} must contain a port"
        return 1
    fi
    if [[ ! "${tab_port}" =~ ^[0-9]+$ ]] ||
        ((10#${tab_port} < 1 || 10#${tab_port} > 65535)); then
        bootstrap_error "${port_variable} must contain a valid TCP port"
        return 1
    fi

    READINESS_PORTS+=("${tab_port}")

    mkdir --parents "${tab_working_directory}"
    chown "${SPACE_USER}:${SPACE_USER}" "${tab_working_directory}"
    chmod u+rwx "${tab_working_directory}"

    service_name="tab-$(tr '[:upper:]_' '[:lower:]-' <<<"${tab_token}")"
    service_directory="${SERVICES_DIRECTORY}/${service_name}"
    environment_file="${service_directory}/environment"
    mkdir --parents "${service_directory}"
    shell_quote quoted_tab_command "${tab_command}"
    shell_quote quoted_tab_port "${tab_port}"
    shell_quote quoted_tab_secret "${tab_secret}"
    shell_quote quoted_tab_direct_token "${tab_direct_token}"
    shell_quote quoted_tab_working_directory "${tab_working_directory}"
    cat >"${environment_file}" <<ENVIRONMENT
TAB_COMMAND=${quoted_tab_command}
TAB_PORT=${quoted_tab_port}
TAB_SECRET=${quoted_tab_secret}
TAB_DIRECT_TOKEN=${quoted_tab_direct_token}
TAB_WORKING_DIRECTORY=${quoted_tab_working_directory}
ENVIRONMENT
    chmod 0600 "${environment_file}"
    shell_quote quoted_environment_file "${environment_file}"
    shell_quote quoted_credentials_ready_file "${CREDENTIALS_READY_FILE}"
    shell_quote quoted_user "${SPACE_USER}"
    shell_quote quoted_home "HOME=${SPACE_HOME}"
    shell_quote quoted_user_environment "USER=${SPACE_USER}"
    shell_quote quoted_logname "LOGNAME=${SPACE_USER}"
    shell_quote quoted_path "PATH=${SPACE_PATH}"
    shell_quote quoted_playwright_browsers_path \
        "PLAYWRIGHT_BROWSERS_PATH=${SPACE_PLAYWRIGHT_BROWSERS_PATH}"
    # Bash exposes only -c for executing the tab command string.
    cat >"${service_directory}/run" <<RUN
#!/bin/bash
exec 2>&1
source ${quoted_environment_file}
export CLOR_WEBTUI_SECRET="\${TAB_SECRET}"
export CLOR_WEBTUI_DIRECT_TOKEN="\${TAB_DIRECT_TOKEN}"
# Wait for the space daemon's first credential pass so the agent never
# starts before its auth files are materialized. The daemon always
# writes the marker (success, failure, revoked, or sync disabled), so
# this only times out when the daemon itself is down.
for ((WAITED = 0; WAITED < ${CREDENTIALS_READY_TIMEOUT_SECONDS}; WAITED++)); do
    if [[ -e ${quoted_credentials_ready_file} ]]; then
        break
    fi
    sleep 1
done
exec gosu ${quoted_user} env \\
    ${quoted_home} ${quoted_user_environment} ${quoted_logname} ${quoted_path} \\
    ${quoted_playwright_browsers_path} \\
    clor webtui serve --persist \\
        --listen-address "0.0.0.0:\${TAB_PORT}" \\
        --working-directory "\${TAB_WORKING_DIRECTORY}" \\
        -- env \\
            --unset=CLOR_WEBTUI_SECRET \\
            --unset=CLOR_WEBTUI_DIRECT_TOKEN \\
            bash --login -c "\${TAB_COMMAND}"
RUN
    chmod 0755 "${service_directory}/run"
    generate_service_logger "${service_name}"
}

generate_tab_services() {
    local variable_name
    local tab_token

    while IFS= read -r variable_name; do
        tab_token="${variable_name#CLOR_TAB_}"
        tab_token="${tab_token%_COMMAND}"
        generate_tab_service "${tab_token}"
    done < <(list_variables '^CLOR_TAB_.*_COMMAND$')
}

generate_readiness_service() {
    local service_directory="${SERVICES_DIRECTORY}/readiness"
    local quoted_ports=""
    local port

    if [[ -d "${SERVICES_DIRECTORY}/desktop-vnc" ]]; then
        READINESS_PORTS+=(5900)
    fi
    if [[ -d "${SERVICES_DIRECTORY}/desktop-web" ]]; then
        READINESS_PORTS+=(6080)
    fi
    for port in "${READINESS_PORTS[@]}"; do
        printf -v quoted_ports '%s %q' "${quoted_ports}" "${port}"
    done

    mkdir --parents "${service_directory}"
    cat >"${service_directory}/run" <<RUN
#!/bin/bash
set -o errexit
set -o nounset
set -o pipefail

READY_FILE=${READY_FILE@Q}
SERVICE_DIRECTORY=${service_directory@Q}
TIMEOUT_SECONDS=${READINESS_TIMEOUT_SECONDS@Q}
PORTS=(${quoted_ports})

rm --force "\${READY_FILE}"
deadline="\$((SECONDS + TIMEOUT_SECONDS))"
while ((SECONDS < deadline)); do
    listening="true"
    for port in "\${PORTS[@]}"; do
        if ! nc -z 127.0.0.1 "\${port}"; then
            listening="false"
            break
        fi
    done
    if [[ "\${listening}" == "true" ]]; then
        : >"\${READY_FILE}"
        : >"\${SERVICE_DIRECTORY}/down"
        exit 0
    fi
    sleep 1
done
printf 'bootstrap: managed services did not become ready within %s seconds\n' \
    "\${TIMEOUT_SECONDS}" >&2
: >"\${SERVICE_DIRECTORY}/down"
exit 1
RUN
    chmod 0755 "${service_directory}/run"
}

generate_services() {
    clear_managed_services
    generate_space_daemon_service
    generate_code_server_service
    generate_tab_services
    generate_readiness_service
}

clear_sensitive_environment() {
    local variable_name

    while IFS= read -r variable_name; do
        unset -- "${variable_name}"
    done < <(list_variables '^CLOR_TAB_.*_(WEBTUI_SECRET|DIRECT_TOKEN)$')
    unset -- CLOR_API_KEY
}

mark_ready() {
    mkdir --parents "$(dirname "${READY_FILE}")"
    : >"${READY_FILE}"
}

prepare_lifecycle_metadata() {
    mkdir --parents "${LIFECYCLE_DIRECTORY}"
    chown root:root "${LIFECYCLE_DIRECTORY}"
    chmod 0755 "${LIFECYCLE_DIRECTORY}"
}

write_lifecycle_file() {
    local destination="$1"
    local contents="$2"
    local temporary_file

    prepare_lifecycle_metadata
    temporary_file="$(mktemp "${LIFECYCLE_DIRECTORY}/metadata.tmp.XXXXXX")"
    printf '%s' "${contents}" >"${temporary_file}"
    chown root:root "${temporary_file}"
    chmod 0644 "${temporary_file}"
    mv --force "${temporary_file}" "${destination}"
}

write_archive_directory() {
    local repository_destination="$1"
    local working_directory="${SPACE_HOME}"

    if [[ -n "${repository_destination}" ]]; then
        working_directory="${repository_destination}"
    fi
    # Bash pwd has no long option and does not accept an option terminator.
    working_directory="$(cd -- "${working_directory}" && pwd -P)"
    write_lifecycle_file "${ARCHIVE_DIRECTORY_FILE}" "${working_directory}"
}

mark_workload_started() {
    write_lifecycle_file "${WORKLOAD_STARTED_FILE}" ""
}

handoff() {
    if (($# > 0)); then
        cd "${SPACE_HOME}"
        mark_ready
        mark_workload_started
        exec gosu "${SPACE_USER}" env \
            HOME="${SPACE_HOME}" \
            USER="${SPACE_USER}" \
            LOGNAME="${SPACE_USER}" \
            PATH="${SPACE_PATH}" \
            PLAYWRIGHT_BROWSERS_PATH="${SPACE_PLAYWRIGHT_BROWSERS_PATH}" \
            "$@"
    fi
    # runsvdir has no long spelling for -P.
    mark_workload_started
    exec runsvdir -P "${SERVICES_DIRECTORY}"
}

main() {
    local repository_destination

    clear_readiness
    prepare_setup_script
    trap cleanup_setup_script EXIT
    validate_configuration
    prepare_user_state
    # Privilege-dropped bootstrap commands must not inherit root's private cwd.
    cd "${SPACE_HOME}"
    configure_clor
    repository_destination="$(prepare_repository)"
    write_archive_directory "${repository_destination}"
    run_setup_script "${repository_destination}"
    cleanup_setup_script
    trap - EXIT
    generate_services
    clear_sensitive_environment
    handoff "$@"
}

main "$@"
