#!/bin/bash
# Stop runit-managed services before the lifecycle coordinator exits or archives.
set -o errexit
set -o nounset
set -o pipefail

if (($# != 1)); then
    printf 'usage: %s tabs|all\n' "$0" >&2
    exit 2
fi

MODE="$1"
SERVICES_DIRECTORY="/etc/service"
WAIT_SECONDS="15"
declare -a services=()

add_supervised_service() {
    local service="$1"

    if [[ -p "${service}/supervise/control" ]]; then
        services+=("${service}")
    fi
    if [[ -p "${service}/log/supervise/control" ]]; then
        services+=("${service}/log")
    fi
}

case "${MODE}" in
    tabs)
        shopt -s nullglob
        for service in "${SERVICES_DIRECTORY}"/tab-*; do
            add_supervised_service "${service}"
        done
        ;;
    all)
        shopt -s nullglob
        for service in "${SERVICES_DIRECTORY}"/*; do
            [[ -d "${service}" ]] || continue
            add_supervised_service "${service}"
        done
        ;;
    *)
        printf 'stop-services: unknown mode %q\n' "${MODE}" >&2
        exit 2
        ;;
esac

if ((${#services[@]} == 0)); then
    exit 0
fi

if ! sv -w "${WAIT_SECONDS}" down "${services[@]}"; then
    printf 'stop-services: graceful stop failed; forcing remaining services down\n' >&2
    sv force-stop "${services[@]}" || true
    exit 1
fi
