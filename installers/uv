#!/bin/bash
set -o errexit
set -o nounset
set -o pipefail

VERSION="$1"

case "$(dpkg --print-architecture)" in
    amd64) ARCH="x86_64" ;;
    arm64) ARCH="aarch64" ;;
    *) echo "unsupported architecture: $(dpkg --print-architecture)" >&2; exit 1 ;;
esac

TARGET="uv-${ARCH}-unknown-linux-gnu"
ARCHIVE="/downloads/${TARGET}-${VERSION}.tar.gz"
URL="https://github.com/astral-sh/uv/releases/download/${VERSION}/${TARGET}.tar.gz"

if [[ ! -f "${ARCHIVE}" ]]; then
    curl --fail --silent --show-error --location \
        --output "${ARCHIVE}" "${URL}"
fi

EXTRACT_DIR="$(mktemp --directory)"
tar --extract --gzip \
    --directory="${EXTRACT_DIR}" \
    --strip-components=1 \
    --file="${ARCHIVE}"
install --mode=0755 "${EXTRACT_DIR}/uv" /usr/local/bin/uv
install --mode=0755 "${EXTRACT_DIR}/uvx" /usr/local/bin/uvx
rm --recursive --force "${EXTRACT_DIR}"
